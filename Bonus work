public void mealPlanner(Set<String> userIngredients, int mealsCount) {

    List<Recipe> result = new ArrayList<>();

    Map<Recipe, Integer> scoreMap = new HashMap<>();

    for (Recipe r : recipes.values()) {

        int match = 0;

        for (String ing : r.ingredients) {
            if (userIngredients.contains(ing)) {
                match++;
            }
        }

        scoreMap.put(r, match);
    }

    // sort by score descending
    List<Map.Entry<Recipe, Integer>> list = new ArrayList<>(scoreMap.entrySet());

    list.sort((a, b) -> b.getValue() - a.getValue());

    int count = 0;

    for (Map.Entry<Recipe, Integer> entry : list) {

        if (count >= mealsCount) break;

        if (entry.getValue() > 0) {
            System.out.println("Meal: " + entry.getKey().name + 
                               " (score=" + entry.getValue() + ")");
            count++;
        }
    }

    if (count == 0) {
        System.out.println("No suitable meals found.");
    }
}




